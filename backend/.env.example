APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://user:password@localhost:5432/nutrimatch?sslmode=disable
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=

JWT_SECRET=change-me
JWT_ISSUER=nutrimatch
JWT_AUDIENCE=nutrimatch_users
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720
REFRESH_TOKEN_PEPPER=change-me

ARGON2_TIME=1
ARGON2_MEMORY=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32
ARGON2_SALT_LENGTH=16

COOKIE_NAME_REFRESH=nm_refresh
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

CORS_ORIGINS=http://localhost:3000
BODY_LIMIT_BYTES=1048576

NUTRITION_API_BASE_URL=
NUTRITION_API_KEY=
AI_API_BASE_URL=
AI_API_KEY=

SPOONACULAR_BASE_URL=https://api.spoonacular.com
SPOONACULAR_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_AI_API_KEY=
